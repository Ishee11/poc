# Poker Session Control local configuration

# Required.
DATABASE_URL=postgres://poker:poker@127.0.0.1:5432/poker?sslmode=disable

# HTTP server.
HTTP_PORT=8080

# Structured JSON logging.
# Values: debug, info, warn, error.
LOG_LEVEL=info

# HTTP access log mode.
# errors: log only 4xx/5xx requests.
# all: log every request.
# off: disable HTTP access logs.
HTTP_ACCESS_LOG=errors

# Public app origin.
APP_ORIGIN=https://semenovv.space

# Blind timer web push.
PUSH_ENABLED=false
PUSH_SUBJECT=mailto:alerts@semenovv.space
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=

# Integration tests safety switch.
# Keep false unless you intentionally run destructive DB tests.
ALLOW_DESTRUCTIVE_INTEGRATION_TESTS=false
